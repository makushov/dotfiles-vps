[alias]
	s = status
	co = checkout
	sw = switch
	br = branch
	ci = commit
	last = log -1 HEAD
	lg = log --oneline --graph --all --decorate -30
	unstage = restore --staged

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default
